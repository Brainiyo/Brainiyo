# ── Server ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── PostgreSQL ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://brainiyo_user:password@localhost:5432/brainiyo_db
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (issued after Firebase verification) ──────────────────────────
JWT_SECRET=change_me_min_32_chars_here_for_production
JWT_EXPIRES_IN=7d

# ── Firebase Admin SDK ────────────────────────────────────────────────
# Project: brainiyo-1c200  (Firebase console → Project Settings → Service accounts)
# Option A: path to service account JSON file (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: inline JSON (for cloud deployments like Render / Cloud Run)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"brainiyo-1c200",...}

# ── Razorpay ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Plan Limits ───────────────────────────────────────────────────────
FREE_DAILY_QUESTIONS=20
PRO_DAILY_QUESTIONS=500
